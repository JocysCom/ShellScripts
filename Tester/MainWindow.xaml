<Window x:Class="JocysCom.Shell.Scripts.Tester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Jocys.com Shell Scripts Tester"
        AutomationProperties.AutomationId="MainWindow.Root"
        Height="520" Width="900"
        Icon="App.ico"
        Closing="Window_Closing"
        Background="{DynamicResource BackgroundLight}"
        Foreground="{DynamicResource ForegroundBlack}"
        SnapsToDevicePixels="True" UseLayoutRounding="True">
	<DockPanel LastChildFill="True">

		<!--  Toolbar  -->
		<Border DockPanel.Dock="Top" Background="{DynamicResource BackgroundDark}" Padding="6">
			<DockPanel LastChildFill="True">
				<Label Content="Scripts folder:" VerticalAlignment="Center" />
				<Button x:Name="BrowseButton" DockPanel.Dock="Right" Content="Browse..." Padding="10,2" Margin="4,0,0,0" Click="BrowseButton_Click" />
				<CheckBox x:Name="DarkThemeCheckBox" DockPanel.Dock="Right" Content="Dark theme" VerticalAlignment="Center" Margin="10,0" Checked="DarkThemeCheckBox_Changed" Unchecked="DarkThemeCheckBox_Changed" />
				<Button x:Name="RefreshButton" DockPanel.Dock="Right" Content="Refresh" Padding="10,2" Margin="4,0,0,0" Click="RefreshButton_Click" />
				<TextBox x:Name="FolderTextBox" AutomationProperties.AutomationId="Main.FolderTextBox" VerticalContentAlignment="Center" Margin="4,0" />
			</DockPanel>
		</Border>

		<!--  Status bar  -->
		<Border DockPanel.Dock="Bottom" Background="{DynamicResource BackgroundDark}" Padding="6,3">
			<TextBlock x:Name="StatusLabel" AutomationProperties.AutomationId="Main.StatusLabel" Text="Ready" />
		</Border>

		<!--  Body: list of scripts + parameter/run pane  -->
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="260" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<ListBox x:Name="ScriptsListBox" AutomationProperties.AutomationId="Main.ScriptsListBox" Margin="6" SelectionChanged="ScriptsListBox_SelectionChanged"
			         DisplayMemberPath="DisplayName"
			         Background="{DynamicResource BackgroundWhite}"
			         Foreground="{DynamicResource ForegroundBlack}" />

			<GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="{DynamicResource BorderDark}" />

			<DockPanel Grid.Column="2" Margin="6" LastChildFill="True">
				<TextBlock x:Name="ScriptHeader" DockPanel.Dock="Top" FontSize="16" FontWeight="Bold" Margin="0,0,0,4" />
				<TextBlock x:Name="ScriptPathLabel" DockPanel.Dock="Top" Opacity="0.7" Margin="0,0,0,6" TextWrapping="Wrap" />
				<Border DockPanel.Dock="Bottom" Margin="0,6,0,0">
					<StackPanel Orientation="Horizontal">
						<Button x:Name="RunButton" AutomationProperties.AutomationId="Main.RunButton" Content="Run" Padding="16,4" Click="RunButton_Click" IsEnabled="False" />
						<Button x:Name="OpenFolderButton" Content="Open Folder" Padding="16,4" Margin="6,0,0,0" Click="OpenFolderButton_Click" IsEnabled="False" />
					</StackPanel>
				</Border>
				<GroupBox Header="Parameters" Padding="6">
					<ScrollViewer VerticalScrollBarVisibility="Auto">
						<StackPanel x:Name="ParametersPanel" />
					</ScrollViewer>
				</GroupBox>
			</DockPanel>
		</Grid>
	</DockPanel>
</Window>
