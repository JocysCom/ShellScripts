{
  "_comment": "Agent sync configuration for Sync-AgentAssets.ps1. The .ai/ folder is the single source of truth.",
  "_sources": {
    "instructions": ".ai/*instructions.md",
    "skills": ".ai/skills/",
    "agents": ".ai/agents/",
    "globalAgents": ".ai/.global/agents/"
  },
  "agents": [
    {
      "name": "Cline",
      "id": "cline",
      "instructions": {
        "mode": "multiple-files",
        "target": ".clinerules"
      },
      "skills": null,
      "agents": null,
      "globalAgents": null,
      "mcp": null
    },
    {
      "name": "Roo Code",
      "id": "roo-code",
      "instructions": {
        "mode": "multiple-files",
        "target": ".roo/rules"
      },
      "skills": { "target": ".roo/skills" },
      "agents": { "target": ".roomodes", "format": "roomodes-json" },
      "globalAgents": {
        "target": "{AppData}/Code/User/globalStorage/rooveterinaryinc.roo-cline/settings/custom_modes.yaml",
        "format": "roomodes-json"
      },
      "mcp": { "config": ".roo/mcp.json" }
    },
    {
      "name": "GitHub Copilot",
      "id": "github-copilot",
      "instructions": {
        "mode": "single-file",
        "target": ".github/copilot-instructions.md",
        "folderTarget": ".github/instructions",
        "mainFile": "instructions.md"
      },
      "skills": { "target": ".github/skills" },
      "agents": null,
      "globalAgents": null,
      "mcp": null
    },
    {
      "name": "OpenAI Codex",
      "id": "openai-codex",
      "instructions": {
        "mode": "single-file",
        "target": "AGENTS.md"
      },
      "skills": null,
      "agents": null,
      "globalAgents": null,
      "mcp": null
    },
    {
      "name": "Claude Code",
      "id": "claude-code",
      "instructions": {
        "mode": "multiple-files",
        "target": ".claude"
      },
      "skills": { "target": ".claude/skills" },
      "agents": { "target": ".claude/agents" },
      "globalAgents": { "target": "{UserProfile}/.claude/agents" },
      "mcp": { "config": ".claude/settings.json" }
    }
  ]
}
